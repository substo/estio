  rejectedByUser User?            @relation("AiSuggestedResponseRejectedBy", fields: [rejectedByUserId], references: [id], onDelete: SetNull)

  @@index([locationId, status, createdAt(sort: Desc)])
  @@index([conversationId, status, createdAt(sort: Desc)])
  @@index([dealId, status, createdAt(sort: Desc)])
  @@index([contactId, status, createdAt(sort: Desc)])
  @@index([decisionId, status, createdAt(sort: Desc)])
}

model Message {
  id             String  @id @default(cuid())
  conversationId String
  ghlMessageId   String? @unique

  type      String // SMS, Email, WhatsApp
  direction String // inbound, outbound
  status    String // sent, delivered, read, failed

  body    String? @db.Text
  subject String? // For emails

  // Metadata for Sync/Direction
  emailFrom String?
  emailTo   String?
  userId    String?
  source    String?

  createdAt DateTime // The actual time the message was sent/received
  updatedAt DateTime @updatedAt

  // Native Gmail Fields
  emailThreadId     String?
  emailMessageId    String? @unique
  emailHeaders      Json? // References, In-Reply-To
  internetMessageId String? @unique // Standard RFC 5322 Message-ID (for cross-provider deduplication)

  // Relations
  conversation                 Conversation                  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments                  MessageAttachment[]
  transcripts                  MessageTranscript[]
  legacyCrmLeadEmailProcessing LegacyCrmLeadEmailProcessing?

  // WhatsApp Integration
  wamId String? @unique // WhatsApp Message ID (for dedup)

  @@index([conversationId])
  @@index([createdAt])
  @@index([conversationId, updatedAt(sort: Desc)])
  @@index([emailThreadId])
}

model LegacyCrmLeadEmailProcessing {
  id                      String    @id @default(cuid())
  messageId               String    @unique
  locationId              String
  status                  String    @default("pending") // pending, processing, processed, failed, ignored, duplicate
  classification          String? // new_lead, follow_up, unknown
  senderEmail             String?
  subject                 String?
  legacyLeadUrl           String?
  legacyLeadId            String?
  extracted               Json?
  parsedLeadPayload       Json?
  processResult           Json?
  processedContactId      String?
  processedConversationId String?
  error                   String?
  attempts                Int       @default(0)
  processedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  message  Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, status])
  @@index([classification])
  @@index([legacyLeadId])
  @@map("legacy_crm_lead_email_processing")
}

model GmailSyncState {
  id              String    @id @default(cuid())
  userId          String    @unique
  emailAddress    String?   @unique // The Gmail address being synced (for webhook lookup)
  historyId       String?
  lastSyncedAt    DateTime  @default(now())
  watchExpiration DateTime? // When the push notification subscription expires

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OutlookSyncState {
  id           String  @id @default(cuid())
  userId       String  @unique
  emailAddress String? @unique // The Outlook address being synced

  // Delta Sync Cursors
  deltaLinkInbox     String? @db.Text
  deltaLinkSentItems String? @db.Text

  deltaLinkContacts String? @db.Text

  lastSyncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId        String
  endpoint      String    @unique
  p256dh        String    @db.Text
  auth          String    @db.Text
  status        String    @default("active") // active, inactive
  deviceLabel   String?
  userAgent     String?   @db.Text
  browser       String?
  platform      String?
  expiration    DateTime?
  lastUsedAt    DateTime?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureCount  Int       @default(0)
  metadata      Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model UserTaskReminderPreference {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId              String  @unique
  enabled             Boolean @default(true)
  inAppEnabled        Boolean @default(true)
  webPushEnabled      Boolean @default(true)
  defaultOffsets      Json?
  quietHoursEnabled   Boolean @default(true)
  quietHoursStartHour Int     @default(21)
  quietHoursEndHour   Int     @default(8)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MessageAttachment {
  id          String @id @default(cuid())
  messageId   String
  fileName    String
  contentType String
  size        Int
  url         String

  message    Message            @relation(fields: [messageId], references: [id], onDelete: Cascade)
  transcript MessageTranscript?

  @@index([messageId])
}

model MessageTranscript {
  id               String    @id @default(cuid())
  messageId        String
  attachmentId     String    @unique
  provider         String    @default("google")
  model            String
  status           String    @default("pending") // pending | processing | completed | failed
  language         String?
  text             String?   @db.Text
  error            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  startedAt        DateTime?
  completedAt      DateTime?
  retryCount       Int       @default(0)
  lastRetryAt      DateTime?
  deadLetteredAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  message     Message                       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  attachment  MessageAttachment             @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  extractions MessageTranscriptExtraction[]

  @@index([messageId])
  @@index([status])
  @@index([status, updatedAt])
  @@index([deadLetteredAt])
  @@index([createdAt])
}

model MessageTranscriptExtraction {
  id               String    @id @default(cuid())
  transcriptId     String
  provider         String    @default("google")
  model            String
  status           String    @default("pending") // pending | processing | completed | failed
  payload          Json?
  error            String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  startedAt        DateTime?
  completedAt      DateTime?
  retryCount       Int       @default(0)
  lastRetryAt      DateTime?
  deadLetteredAt   DateTime?
  crmLogHistoryId  String?
  crmLoggedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  transcript MessageTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId])
  @@index([status])
  @@index([status, updatedAt])
  @@index([deadLetteredAt])
  @@index([createdAt])
}

model WhatsAppImportSession {
  id              String   @id @default(cuid())
  locationId      String
  fileName        String
  status          String   @default("pending") // pending, mapping, importing, complete, failed
  rawContent      String   @db.Text
  parsedData      Json? // Parsed messages before final import
  contactMappings Json? // { "Display Name": "contactId" }
  uniqueAuthors   String[] @default([]) // List of unique sender names for easy mapping UI
  messageCount    Int      @default(0)
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@index([status])
}

model Insight {
  id             String        @id @default(cuid())
  contactId      String
  contact        Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  dealId         String?

  // Content
  text       String @db.Text // The raw insight text
  category   String // "preference", "objection", "timeline", "motivation", "relationship"
  importance Int    @default(5) // 1-10 scale
  source     String // "agent_extracted", "user_noted", "system_inferred"

  // Metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime? // Some insights are time-bound

  @@index([contactId])
  @@index([conversationId])
  @@map("insights")
}

model PlaybookEntry {
  id        String   @id @default(cuid())
  text      String   @db.Text
  category  String
  createdAt DateTime @default(now())

  @@map("playbook_entries")
}

// Phase 6: Event-Driven Architecture — Event Log
model AgentEvent {
  id             String   @id @default(cuid())
  type           String // EventType: message.received, lead.created, follow_up.due, etc.
  payload        Json
  conversationId String?
  contactId      String?
  status         String   @default("processed") // processing, processed, error
  error          String?
  processedAt    DateTime @default(now())

  @@index([type, processedAt])
  @@map("agent_events")
}

// ==========================================
// Phase 2: Strategic Scraping Infrastructure
// ==========================================

model ScrapingConnection {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  locationId String

  name     String
  platform String // e.g., "bazaraki", "facebook_marketplace"
  enabled  Boolean @default(true)

  // Rate Limits
  globalRateLimitMs     Int @default(5000)
  maxDailyInteractions  Int @default(100) // Hard limit on deep interactions per day per connection
  maxConcurrentRequests Int @default(1) // Control parallel Playwright contexts

  location    Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  tasks       ScrapingTask[]
  credentials ScrapingCredential[]

  @@index([locationId, enabled])
  @@index([platform])
}

model ScrapingCredential {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  connectionId String

  // Authentication Details (Encrypted/Secure)
  authUsername String?
  authPassword String? @db.Text

  // Session State (Cookies/Tokens to avoid re-login)
  sessionState Json? // Storing Playwright context cookies

  // Health & Rotation
  status      String    @default("active") // active, rate_limited, banned, locked
  healthScore Int       @default(100) // 1-100 scale, degrades on 429s/captchas
  lastUsedAt  DateTime?

  connection ScrapingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, status])
  @@index([lastUsedAt])
}

model ScrapingTask {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  locationId   String
  connectionId String

  name            String
  enabled         Boolean @default(true)
  scrapeFrequency String  @default("daily") // hourly, every_6h, daily, weekly
  maxPagesPerRun  Int     @default(10)
  extractionMode  String  @default("hybrid") // css_selectors, ai_extraction, hybrid
  selectors       Json? // CSS selector mapping
  aiInstructions  String? @db.Text // AI extraction prompt
  taskType        String  @default("listings") // listings, social_posts, profiles

  // Scrape Strategy
  scrapeStrategy        String @default("shallow_duplication") // shallow_duplication, deep_extraction
  targetSellerType      String @default("individual") // individual, agency, all
  delayBetweenPagesMs   Int    @default(3000) // Base wait between actions
  delayJitterMs         Int    @default(1500) // Random variance added
  maxInteractionsPerRun Int? // Optional hard cap on deep actions per run

  // Target Execution specifics
  targetUrls       String[] @default([]) // Array of specific URLs to scrape (e.g. /real-estate-for-sale/)
  targetProspectId String? // Bind all listings to this CRM prospect
  fieldMappings    Json? // Flexible JSON for mapping fields dynamically per platform

  // Sync state
  lastSyncAt     DateTime?
  lastSyncStatus String?
  lastSyncError  String?   @db.Text
  lastSyncStats  Json? // { discovered: 15, new: 8, duplicates: 7, errors: 0 }

  location   Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  connection ScrapingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  runs       ScrapingRun[]
  deepScrapeStages DeepScrapeRunStage[]

  @@index([locationId, enabled])
  @@index([connectionId])
}

model ScrapingRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  taskId    String

  status          String    @default("running") // running, completed, partial, failed
  pagesScraped    Int       @default(0)
  listingsFound   Int       @default(0)
  leadsCreated    Int       @default(0)
  duplicatesFound Int       @default(0)
  errors          Int       @default(0)
  completedAt     DateTime?
  errorLog        String?   @db.Text
  metadata        Json?

  task ScrapingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt(sort: Desc)])
}

model DeepScrapeRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  locationId String

  status          String    @default("running") // running, completed, partial, failed
  triggeredBy     String?
  triggeredByUserId String?
  queueJobId      String?
  queuedAt        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  errorLog        String?   @db.Text
  configSnapshot  Json?
  metadata        Json?

  tasksScanned    Int       @default(0)
  tasksStarted    Int       @default(0)
  tasksCompleted  Int       @default(0)
  tasksSkipped    Int       @default(0)

  rootUrlsProcessed          Int @default(0)
  indexPagesScraped          Int @default(0)
  seedListingsFound          Int @default(0)
  seedListingsNew            Int @default(0)
  seedListingsDuplicate      Int @default(0)
  prospectsCreated           Int @default(0)
  prospectsMatched           Int @default(0)
  contactsWithPhone          Int @default(0)
  contactsWithoutPhone       Int @default(0)
  sellerPortfoliosDiscovered Int @default(0)
  portfolioListingsDeepScraped Int @default(0)

  omittedAgency           Int @default(0)
  omittedUncertain        Int @default(0)
  omittedMissingPhone     Int @default(0)
  omittedNonRealEstate    Int @default(0)
  omittedDuplicate        Int @default(0)
  omittedBudgetExhausted  Int @default(0)

  errorsAuth        Int @default(0)
  errorsNetwork     Int @default(0)
  errorsExtraction  Int @default(0)
  errorsUnknown     Int @default(0)
  errorsTotal       Int @default(0)

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  stages   DeepScrapeRunStage[]

  @@index([locationId, createdAt(sort: Desc)])
  @@index([locationId, status, createdAt(sort: Desc)])
}

model DeepScrapeRunStage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  runId     String
  locationId String
  taskId    String?

  stage      String
  status     String   @default("info") // info, success, warning, error, skipped
  reasonCode String?
  message    String?  @db.Text
  counters   Json?
  metadata   Json?

  run      DeepScrapeRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  location Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  task     ScrapingTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([runId, createdAt(sort: Desc)])
  @@index([locationId, createdAt(sort: Desc)])
  @@index([taskId, createdAt(sort: Desc)])
  @@index([reasonCode])
  @@index([stage])
}

model ScrapedListing {
  id         String @id @default(cuid())
  locationId String

  platform   String // "bazaraki", "facebook"
  externalId String // Original ID for deduplication
  url        String

  title        String?
  description  String?  @db.Text
  price        Int?
  currency     String?  @default("EUR")
  propertyType String?
  listingType  String?  // "rent" | "sale"
  locationText String?
  images       String[]
  thumbnails   String[] @default([])

  // Property Details
  bedrooms         Int?
  bathrooms        Int?
  propertyArea     Int?     // m²
  plotArea         Int?     // m²
  constructionYear Int?

  // Geo
  latitude  Float?
  longitude Float?

  // Seller Intelligence
  sellerExternalId   String?   // Bazaraki user ID (e.g. "9431239")
  sellerRegisteredAt String?   // "Posting since sep, 2024"
  otherListingsUrl   String?   // Link to seller's other ads
  otherListingsCount Int?      // Number of other listings
  contactChannels    String[]  @default([]) // ["whatsapp","chat","email"]
  whatsappPhone      String?   // Parsed from WhatsApp button href

  // Flexible catch-all for all listing attributes
  rawAttributes Json?    // All key-value pairs from chars-column

  isExpired Boolean @default(false)
  status String @default("NEW") // NEW, REVIEWING, IMPORTED, REJECTED, SKIPPED

  // Link to imported Property (set when contact is accepted and property is imported)
  importedPropertyId String?

  // Link to the Prospect / Person
  prospectLeadId String?
  prospectLead   ProspectLead? @relation(fields: [prospectLeadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, externalId])
}
