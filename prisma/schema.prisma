model Conversation {
  id                String @id @default(cuid())
  locationId        String
  contactId         String
  ghlConversationId String @unique

  status           String   @default("open")
  lastMessageBody  String?  @db.Text
  lastMessageAt    DateTime @default(now())
  lastMessageType  String? // TYPE_SMS, TYPE_EMAIL, TYPE_WHATSAPP
  unreadCount      Int      @default(0)
  suggestedActions String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete & Archive
  deletedAt  DateTime? // Soft delete timestamp (null = active, not null = in trash)
  archivedAt DateTime? // Archive timestamp (null = not archived, not null = archived)
  deletedBy  String? // User ID who deleted (for audit trail)

  // AI Agent Planner
  agentPlan Json? // Stores the structured task list [ { id, title, status, result } ]

  // Accumulated Usage Stats
  // Accumulated Usage Stats
  promptTokens     Int   @default(0)
  completionTokens Int   @default(0)
  totalTokens      Int   @default(0)
  totalCost        Float @default(0)

  // Phase 6: Semi-Auto & Event-Driven
  semiAuto              Boolean   @default(false) // AI auto-drafts on incoming events (never auto-sends)
  replyLanguageOverride String? // Optional per-conversation language override (BCP-47, null = auto)
  contextSummary        String?   @db.Text // Compacted conversation context for long threads
  lastSummarizedAt      DateTime? // When context was last compacted

  // Relations
  location             Location                  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  contact              Contact                   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages             Message[]
  executions           AgentExecution[]
  participants         ConversationParticipant[]
  insights             Insight[]
  contactTasks         ContactTask[]
  userNotifications    UserNotification[]
  aiAutomationJobs     AiAutomationJob[]
  aiDecisions          AiDecision[]
  aiSuggestedResponses AiSuggestedResponse[]

  @@unique([locationId, contactId])
  @@index([locationId])
  @@index([contactId])
  @@index([lastMessageAt])
  @@index([deletedAt])
  @@index([archivedAt])
  @@index([locationId, deletedAt, archivedAt, lastMessageAt(sort: Desc), id(sort: Desc)])
  @@index([locationId, deletedAt, lastMessageAt(sort: Desc), id(sort: Desc)])
  @@index([locationId, updatedAt(sort: Asc), id(sort: Asc)])
}

model ContactTask {
