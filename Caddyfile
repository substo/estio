{
    # Global On-Demand TLS Configuration
    on_demand_tls {
        ask http://localhost:3000/api/verify-domain
    }
}

estio.co {
    reverse_proxy localhost:3000
    
    # STANDARD PROXY - NO SPOOFING
    # We pass the real Host header. Next.js sees 'estio.co'.
    # This matches the user's description of the "previous working state"
}

:80 {
    redir https://{host}{uri} permanent
}

:443 {
    @ip_request header Host 138.199.214.117
    abort @ip_request

    tls {
        on_demand
    }
    reverse_proxy localhost:3000
    
    # STANDARD PROXY - NO SPOOFING
}
